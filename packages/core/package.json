{
  "name": "@pip-it-up/core",
  "version": "0.1.3",
  "description": "Vanilla JS engine for the Document Picture-in-Picture API — move, clone, or portal any DOM element into a floating PiP window",
  "keywords": [
    "picture-in-picture",
    "pip",
    "document-picture-in-picture",
    "floating-window",
    "pip-window",
    "document-pip",
    "pip-api",
    "web-api",
    "browser-api",
    "vanilla-js",
    "framework-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shakya47/pip-it-up.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Shakya47/pip-it-up/issues"
  },
  "homepage": "https://github.com/Shakya47/pip-it-up/tree/main/packages/core#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "src/global.d.ts"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
